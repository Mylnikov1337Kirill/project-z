{
  "name": "agent-trail",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "node scripts/run-with-supported-node.mjs vite",
    "prod:local": "bash scripts/run-prod-local.sh",
    "build": "node scripts/run-with-supported-node.mjs tsc -b && node scripts/run-with-supported-node.mjs vite build && node scripts/run-with-supported-node.mjs node scripts/check-browser-bundle-answer-keys.mjs",
    "build:server": "node scripts/run-with-supported-node.mjs node scripts/build-server.mjs",
    "db:migrate": "node scripts/run-with-supported-node.mjs node scripts/db-migrate.mjs",
    "lint": "node scripts/run-with-supported-node.mjs eslint .",
    "preview": "node scripts/run-with-supported-node.mjs vite preview",
    "start:server": "node scripts/run-with-supported-node.mjs node dist-server/index.mjs",
    "security:bundle": "node scripts/run-with-supported-node.mjs node scripts/check-browser-bundle-answer-keys.mjs",
    "test": "node scripts/run-with-supported-node.mjs npm run test:e2e",
    "test:e2e": "node scripts/run-with-supported-node.mjs playwright test",
    "test:unit": "node scripts/run-with-supported-node.mjs vitest run --config vitest.config.ts",
    "validate:content": "node scripts/run-with-supported-node.mjs vitest run --config vitest.config.ts src/entities/chapter/model/chapterCatalog.content.test.ts",
    "typecheck": "node scripts/run-with-supported-node.mjs tsc -b --pretty false"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "esbuild": "^0.27.7",
    "eslint": "10.4.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.6.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.0",
    "vite": "8.0.14",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "pg": "^8.21.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-router-dom": "7.16.0"
  }
}
